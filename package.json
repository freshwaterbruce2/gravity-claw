{
  "name": "gravity-claw",
  "version": "0.2.0",
  "description": "AI agent orchestrator desktop application",
  "author": "Bruce Freshwater",
  "main": "electron/main.mjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5177",
    "server": "tsx server/src/index.ts",
    "server:dev": "tsx watch server/src/index.ts",
    "start": "concurrently \"pnpm dev\" \"pnpm server:dev\" --names \"ui,api\" --prefix-colors \"yellow,cyan\"",
    "start:full": "concurrently \"pnpm dev\" \"pnpm server:dev\" \"node --import tsx ../../apps/mcp-gateway/src/index.ts\" \"pnpm inngest:dev\" --names \"ui,api,mcp,inngest\" --prefix-colors \"yellow,cyan,green,magenta\"",
    "desktop": "electron electron/main.mjs",
    "desktop:dev": "node scripts/start-desktop-dev.mjs",
    "build": "pnpm run typecheck && pnpm run typecheck:server && vite build",
    "preview": "vite preview",
    "test": "node --import tsx --test src/lib/runtime.test.ts src/lib/authBridge.test.ts src/stores/taskStore.test.ts server/src/config.test.ts server/src/mcp-status.test.ts server/src/tasks.test.ts scripts/runtime-paths.test.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "lint": "eslint src --ext ts,tsx",
    "self-improve": "powershell -ExecutionPolicy Bypass -File scripts/apply-improvement.ps1",
    "inngest:dev": "node scripts/start-inngest-dev.mjs",
    "build:server": "node scripts/bundle-server.mjs",
    "build:electron": "pnpm run build && pnpm run build:server && electron-builder --win --config electron-builder.config.cjs",
    "dist": "electron-builder --win --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.7",
    "@vibetech/inngest-client": "workspace:*",
    "dotenv": "^16.4.7",
    "hono": "^4.7.7",
    "inngest": "^3.52.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "telegraf": "^4.16.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "electron": "40.1.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
