{
  "name": "@vibetech/gravity-claw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5177",
    "server": "tsx server/src/index.ts",
    "server:dev": "tsx watch server/src/index.ts",
    "start": "concurrently \"pnpm dev\" \"pnpm server:dev\" --names \"ui,api\" --prefix-colors \"yellow,cyan\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "self-improve": "powershell -ExecutionPolicy Bypass -File scripts/apply-improvement.ps1"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
